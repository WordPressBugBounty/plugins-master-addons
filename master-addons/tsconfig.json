{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowJs": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@shared/*": ["./dev/js/admin/shared/*"],
      "@adminSettings/*": ["./dev/js/admin/admin-settings/src/*"],
      "@setupWizard/*": ["./dev/js/admin/setup-wizard/src/*"]
    }
  },
  "include": ["dev"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
